{
  "$schema": "https://raw.githubusercontent.com/nicholascm/tauri/main/crates/tauri-config-schema/schema.json",
  "build": {
    "beforeBuildCommand": "npx expo export --platform web",
    "frontendDist": "../dist"
  },
  "productName": "The Executive",
  "version": "0.1.0",
  "identifier": "com.executive.app",
  "app": {
    "windows": [
      {
        "title": "The Executive",
        "width": 420,
        "height": 900,
        "resizable": true,
        "minWidth": 380,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
