{
  "expo": {
    "name": "Eisenhower Matrix Productivity",
    "slug": "eisenhower-matrix",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "eisenhower-reminder",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#fbf9f9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.executive.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      "expo-localization"
    ],
    "android": {
      "package": "com.executive.app"
    }
  }
}
